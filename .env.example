# ──── Database (SRS Section 2.4) ────
POSTGRES_USER=fradupix
POSTGRES_PASSWORD=fradupix_secure_2024
POSTGRES_DB=fradupix
DATABASE_URL=postgresql://fradupix:fradupix_secure_2024@db:5432/fradupix

# ──── Redis (SRS Section 2.4) ────
REDIS_URL=redis://redis:6379/0

# ──── JWT Authentication (SRS Section 11.1) ────
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# ──── MinIO / S3 Storage (SRS Section 2.4) ────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=invoices
S3_ENDPOINT=http://minio:9000

# ──── Celery Task Queue (SRS Section 2.4) ────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_CONCURRENCY=4

# ──── Encryption (SRS Section 11.2) ────
ENCRYPTION_KEY=your-fernet-key-generate-via-cryptography

# ──── Risk Score Weights (SRS Appendix A) ────
RISK_WEIGHT_FORGERY=0.30
RISK_WEIGHT_DUPLICATE=0.25
RISK_WEIGHT_ANOMALY=0.25
RISK_WEIGHT_RULES=0.20

# ──── Risk Thresholds (SRS FR-702) ────
RISK_THRESHOLD_LOW=30
RISK_THRESHOLD_MEDIUM=60
RISK_THRESHOLD_HIGH=85

# ──── Duplicate Detection (SRS FR-500) ────
DUPLICATE_TIME_WINDOW_DAYS=90
FUZZY_MATCH_THRESHOLD=0.15
SEMANTIC_SIMILARITY_THRESHOLD=0.85

# ──── Service URLs (SRS Appendix D) ────
OCR_SERVICE_URL=http://invoicefirewall-ocr:8001
ML_SERVICE_URL=http://invoicefirewall-ml:8002

# ──── App Settings ────
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
BATCH_UPLOAD_LIMIT=1000
